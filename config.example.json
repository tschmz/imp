{
  "instance": {
    "name": "home"
  },
  "paths": {
    "dataRoot": "/var/lib/imp"
  },
  "logging": {
    "level": "info"
  },
  "defaults": {
    "agentId": "default"
  },
  "agents": [
    {
      "id": "default",
      "model": {
        "provider": "openai-codex",
        "modelId": "gpt-5.4"
      },
      "authFile": "/var/lib/imp/auth.json",
      "tools": [
        "read",
        "bash",
        "edit",
        "write",
        "grep",
        "find",
        "ls"
      ],
      "context": {
        "workingDirectory": "/path/to/workspace",
        "files": [
          "/path/to/workspace/AGENTS.md"
        ]
      },
      "systemPrompt": "You are a concise and pragmatic assistant running through a local daemon."
    },
    {
      "id": "ops",
      "name": "Operations",
      "model": {
        "provider": "openai",
        "modelId": "gpt-5.4"
      },
      "tools": [
        "read",
        "bash",
        "edit",
        "write",
        "grep",
        "find",
        "ls"
      ],
      "context": {
        "workingDirectory": "/path/to/ops-workspace",
        "files": [
          "/path/to/ops-workspace/AGENTS.md",
          "/path/to/ops-workspace/RUNBOOK.md"
        ]
      },
      "inference": {
        "metadata": {
          "app": "imp",
          "role": "ops"
        },
        "request": {
          "store": true,
          "reasoning": {
            "effort": "medium"
          },
          "text": {
            "verbosity": "low"
          }
        }
      },
      "systemPrompt": "You are a concise operations assistant focused on diagnostics, runbooks, and safe remediation steps."
    }
  ],
  "bots": [
    {
      "id": "private-telegram",
      "type": "telegram",
      "enabled": true,
      "token": "replace-me",
      "access": {
        "allowedUserIds": []
      }
    },
    {
      "id": "ops-telegram",
      "type": "telegram",
      "enabled": false,
      "token": "replace-me-too",
      "access": {
        "allowedUserIds": []
      },
      "routing": {
        "defaultAgentId": "ops"
      }
    }
  ]
}

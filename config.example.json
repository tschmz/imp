{
  "instance": {
    "name": "home"
  },
  "paths": {
    "dataRoot": "/var/lib/imp"
  },
  "logging": {
    "level": "info",
    "rotationSize": "5M"
  },
  "defaults": {
    "agentId": "default",
    "model": {
      "provider": "openai-codex",
      "modelId": "gpt-5.4",
      "authFile": "/var/lib/imp/auth.json",
      "inference": {
        "metadata": {
          "app": "imp"
        },
        "request": {
          "store": true
        }
      }
    }
  },
  "tools": {
    "mcp": {
      "inheritEnv": [
        "GITHUB_TOKEN"
      ],
      "servers": [
        {
          "id": "docs",
          "command": "node",
          "args": [
            "/opt/imp/mcp/docs-server.mjs"
          ],
          "inheritEnv": [
            "OPENAI_API_KEY"
          ],
          "cwd": "/var/lib/imp/tools"
        }
      ]
    }
  },
  "agents": [
    {
      "id": "default",
      "tools": {
        "builtIn": [
          "read",
          "bash",
          "edit",
          "write",
          "grep",
          "find",
          "ls",
          "update_plan"
        ],
        "agents": [
          {
            "agentId": "ops"
          }
        ],
        "mcp": {
          "servers": [
            "docs"
          ]
        }
      },
      "prompt": {
        "instructions": [
          {
            "file": "/var/lib/imp/agents/default/AGENTS.md"
          }
        ]
      },
      "workspace": {
        "cwd": "/var/lib/imp/agents/default/workspace",
        "shellPath": [
          "/home/example/.local/bin",
          "/usr/local/bin",
          "/usr/bin",
          "/bin"
        ]
      },
      "skills": {
        "paths": [
          "/path/to/shared-skills"
        ]
      }
    },
    {
      "id": "ops",
      "name": "Operations",
      "model": {
        "provider": "openai",
        "modelId": "gpt-5.4",
        "apiKey": {
          "env": "OPENAI_API_KEY"
        },
        "inference": {
          "metadata": {
            "app": "imp",
            "role": "ops"
          },
          "request": {
            "store": true,
            "reasoning": {
              "effort": "medium"
            },
            "text": {
              "verbosity": "low"
            }
          }
        }
      },
      "tools": [
        "read",
        "bash",
        "edit",
        "write",
        "grep",
        "find",
        "ls",
        "update_plan"
      ],
      "prompt": {
        "base": {
          "text": "You are a concise operations assistant focused on diagnostics, runbooks, and safe remediation steps."
        },
        "instructions": [
          {
            "file": "/var/lib/imp/agents/ops/AGENTS.md"
          }
        ],
        "references": [
          {
            "file": "/var/lib/imp/agents/ops/RUNBOOK.md"
          }
        ]
      },
      "workspace": {
        "cwd": "/var/lib/imp/agents/ops/workspace",
        "shellPath": [
          "/usr/local/bin",
          "/usr/bin",
          "/bin"
        ]
      }
    }
  ],
  "plugins": [
    {
      "id": "pi-audio",
      "enabled": false,
      "package": {
        "path": "/opt/imp/plugins/pi-audio"
      }
    },
    {
      "id": "notes",
      "enabled": false
    }
  ],
  "endpoints": [
    {
      "id": "private-telegram",
      "type": "telegram",
      "enabled": true,
      "token": {
        "env": "IMP_PRIVATE_TELEGRAM_BOT_TOKEN"
      },
      "access": {
        "allowedUserIds": []
      },
      "voice": {
        "enabled": true,
        "transcription": {
          "provider": "openai",
          "model": "gpt-4o-mini-transcribe"
        }
      },
      "document": {
        "maxDownloadBytes": 20971520
      }
    },
    {
      "id": "ops-telegram",
      "type": "telegram",
      "enabled": false,
      "token": {
        "file": "./secrets/ops-telegram.token"
      },
      "access": {
        "allowedUserIds": []
      },
      "routing": {
        "defaultAgentId": "ops"
      }
    },
    {
      "id": "audio-ingress",
      "type": "file",
      "enabled": false,
      "pluginId": "pi-audio",
      "routing": {
        "defaultAgentId": "default"
      },
      "ingress": {
        "pollIntervalMs": 500,
        "maxEventBytes": 65536
      },
      "response": {
        "type": "outbox",
        "replyChannel": {
          "kind": "audio"
        }
      }
    }
  ]
}

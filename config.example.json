{
  "instance": {
    "name": "home"
  },
  "paths": {
    "dataRoot": "/var/lib/pi-daemon"
  },
  "logging": {
    "level": "info"
  },
  "defaults": {
    "agentId": "default",
    "model": {
      "provider": "openai",
      "modelId": "gpt-5.4"
    }
  },
  "bots": [
    {
      "id": "private-telegram",
      "type": "telegram",
      "enabled": true,
      "token": "replace-me",
      "access": {
        "allowedUserIds": []
      }
    }
  ]
}

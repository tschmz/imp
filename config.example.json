{
  "instance": {
    "name": "home"
  },
  "paths": {
    "dataRoot": "/var/lib/imp"
  },
  "logging": {
    "level": "info"
  },
  "defaults": {
    "agentId": "default"
  },
  "agents": [
    {
      "id": "default",
      "model": {
        "provider": "openai-codex",
        "modelId": "gpt-5.4"
      },
      "authFile": "/var/lib/imp/auth.json",
      "tools": [
        "read",
        "bash",
        "edit",
        "write",
        "grep",
        "find",
        "ls"
      ],
      "prompt": {
        "base": {
          "file": "/var/lib/imp/SYSTEM.md"
        },
        "instructions": [
          {
            "file": "/path/to/workspace/AGENTS.md"
          }
        ]
      },
      "workspace": {
        "cwd": "/path/to/workspace",
        "shellPath": [
          "/home/example/.local/bin",
          "/usr/local/bin",
          "/usr/bin",
          "/bin"
        ]
      }
    },
    {
      "id": "ops",
      "name": "Operations",
      "model": {
        "provider": "openai",
        "modelId": "gpt-5.4"
      },
      "tools": [
        "read",
        "bash",
        "edit",
        "write",
        "grep",
        "find",
        "ls"
      ],
      "prompt": {
        "base": {
          "text": "You are a concise operations assistant focused on diagnostics, runbooks, and safe remediation steps."
        },
        "instructions": [
          {
            "file": "/path/to/ops-workspace/AGENTS.md"
          }
        ],
        "references": [
          {
            "file": "/path/to/ops-workspace/RUNBOOK.md"
          }
        ]
      },
      "workspace": {
        "cwd": "/path/to/ops-workspace",
        "shellPath": [
          "/usr/local/bin",
          "/usr/bin",
          "/bin"
        ]
      },
      "inference": {
        "metadata": {
          "app": "imp",
          "role": "ops"
        },
        "request": {
          "store": true,
          "reasoning": {
            "effort": "medium"
          },
          "text": {
            "verbosity": "low"
          }
        }
      }
    }
  ],
  "bots": [
    {
      "id": "private-telegram",
      "type": "telegram",
      "enabled": true,
      "token": "replace-me",
      "access": {
        "allowedUserIds": []
      }
    },
    {
      "id": "ops-telegram",
      "type": "telegram",
      "enabled": false,
      "token": "replace-me-too",
      "access": {
        "allowedUserIds": []
      },
      "routing": {
        "defaultAgentId": "ops"
      }
    }
  ]
}

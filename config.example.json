{
  "instance": {
    "name": "home"
  },
  "paths": {
    "dataRoot": "/var/lib/pi-daemon"
  },
  "logging": {
    "level": "info"
  },
  "defaults": {
    "agentId": "default"
  },
  "agents": [
    {
      "id": "default",
      "model": {
        "provider": "openai",
        "modelId": "gpt-5.4"
      },
      "inference": {
        "metadata": {
          "app": "imp"
        },
        "request": {
          "store": true,
          "reasoning": {
            "effort": "medium"
          },
          "text": {
            "verbosity": "low"
          }
        }
      },
      "systemPrompt": "You are a concise and pragmatic assistant running through a local daemon."
    }
  ],
  "bots": [
    {
      "id": "private-telegram",
      "type": "telegram",
      "enabled": true,
      "token": "replace-me",
      "access": {
        "allowedUserIds": []
      }
    }
  ]
}

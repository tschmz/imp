{
  "name": "@tschmz/imp",
  "version": "0.11.0",
  "private": false,
  "description": "A lightweight local daemon for modular agent endpoints",
  "type": "module",
  "bin": {
    "imp": "./dist/main.js"
  },
  "files": [
    "dist",
    "config.example.json",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/main.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "start": "node dist/main.js",
    "prepublishOnly": "npm run clean && npm run check && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@mariozechner/pi-agent-core": "^0.67.68",
    "@mariozechner/pi-ai": "^0.67.68",
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@mariozechner/pi-tui": "^0.67.68",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "grammy": "^1.42.0",
    "handlebars": "^4.7.9",
    "mdast-util-from-markdown": "^2.0.3",
    "npm-package-arg": "^12.0.2",
    "proper-lockfile": "^4.1.2",
    "tar-stream": "^3.1.8",
    "write-file-atomic": "^6.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/npm-package-arg": "^6.1.4",
    "@types/proper-lockfile": "^4.1.4",
    "@types/tar-stream": "^3.1.4",
    "@types/write-file-atomic": "^4.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.2.4"
  }
}

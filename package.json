{
  "name": "pi-claw",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight local daemon for pi-based agents",
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  }
}

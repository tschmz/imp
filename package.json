{
  "name": "@tschmz/imp",
  "version": "0.1.1",
  "private": false,
  "description": "A lightweight local daemon for modular agent endpoints",
  "type": "module",
  "bin": {
    "imp": "./dist/main.js"
  },
  "files": [
    "dist",
    "config.example.json",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/main.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "start": "node dist/main.js",
    "prepublishOnly": "npm run clean && npm run check && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "8.3.2",
    "@mariozechner/pi-agent-core": "^0.65.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "0.65.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "14.0.3",
    "grammy": "^1.42.0",
    "handlebars": "4.7.9",
    "yaml": "2.8.3",
    "zod": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.2.4"
  }
}

{
  "name": "pi-claw",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight, opinionated OpenClaw-like layer built on top of pi",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "pi": {
    "extensions": [
      "./src"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  }
}

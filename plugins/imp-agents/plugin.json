{
  "schemaVersion": 1,
  "id": "imp-agents",
  "name": "Imp Agent Pack",
  "version": "0.1.0",
  "description": "Specialized Imp agents and practical reference tools.",
  "runtime": {
    "module": "./plugin.mjs"
  },
  "agents": [
    {
      "id": "cody",
      "name": "Cody",
      "prompt": {
        "base": {
          "file": "./prompts/cody.md"
        },
        "references": [
          {
            "file": "./README.md"
          }
        ]
      },
      "skills": {
        "paths": [
          "./skills"
        ]
      },
      "tools": {
        "builtIn": [
          "read",
          "grep",
          "find",
          "ls",
          "bash",
          "edit",
          "write",
          "update_plan",
          "load_skill",
          "pwd",
          "cd",
          "workspaceSnapshot"
        ]
      }
    }
  ]
}
